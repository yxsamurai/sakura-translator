{
  "manifest_version": 3,
  "name": "Sakura Translator",
  "version": "1.0.0",
  "description": "A clean Chinese-English translator. Select text with a configurable hotkey to translate words and sentences instantly. Supports PDF translation.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils/detector.js", "utils/translator.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdfjs/pdf.js",
        "lib/pdfjs/pdf.worker.js",
        "pdf-viewer.html",
        "pdf-viewer.js",
        "pdf-viewer.css",
        "content/content.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
